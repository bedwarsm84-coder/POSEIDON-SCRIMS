# ── POSEIDON SCRIMS BOT — ENV CONFIG ──────────────────────────
# Copy this file to .env and fill in your values. NEVER commit .env!

# Discord Bot Token (from discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Discord Application Client ID
CLIENT_ID=your_client_id_here

# Your Discord Server (Guild) ID
GUILD_ID=your_guild_id_here

# MongoDB Connection String (from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/poseidon?retryWrites=true&w=majority

# ── CHANNEL IDs (copy from Discord — right-click channel → Copy ID) ──
SCRIM_RESULTS_CHANNEL=channel_id_here
LEADERBOARD_CHANNEL=channel_id_here
ANNOUNCEMENTS_CHANNEL=channel_id_here
QUEUE_CHANNEL=channel_id_here
LOG_CHANNEL=channel_id_here

# ── ROLE IDs ──
VERIFIED_ROLE=role_id_here
CLAN_LEADER_ROLE=role_id_here
STAFF_ROLE=role_id_here
